{
  "name": "cagnard",
  "private": true,
  "scripts": {
    "backend:test": "cd backend-go && go test ./...",
    "backend:go:test": "cd backend-go && go test ./...",
    "frontend:check": "pnpm --filter @cagnard/frontend typecheck",
    "examples:compose:check": "bash scripts/validate-compose-examples.sh",
